{
  "name": "@openmrs/esm-chartsearchai-app",
  "version": "1.0.0",
  "license": "MPL-2.0",
  "description": "AI-powered chart search for OpenMRS O3",
  "browser": "dist/openmrs-esm-chartsearchai-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "build": "rspack --mode production",
    "lint": "eslint src --ext js,jsx,ts,tsx --max-warnings 0",
    "test": "jest --config jest.config.js --passWithNoTests",
    "test:watch": "jest --watch --config jest.config.js",
    "coverage": "jest --config jest.config.js --coverage",
    "typescript": "bash -c \"tsc --noEmit 2>&1 | (grep '^src/' || true) | (! grep .)\"",
    "extract-translations": "i18next 'src/**/*.component.tsx' --config ./tools/i18next-parser.config.js"
  },
  "keywords": [
    "openmrs",
    "microfrontends",
    "chartsearchai",
    "ai"
  ],
  "homepage": "https://github.com/openmrs/openmrs-esm-chartsearchai#readme",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmrs/openmrs-esm-chartsearchai.git"
  },
  "bugs": {
    "url": "https://github.com/openmrs/openmrs-esm-chartsearchai/issues"
  },
  "dependencies": {
    "@carbon/react": "^1.83.0"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "*",
    "react": "18.x",
    "react-i18next": "16.x"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "next",
    "@openmrs/esm-styleguide": "next",
    "@swc/jest": "^0.2.36",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^15.0.6",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-ts-react-important-stuff": "^3.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "i18next": "^25.6.2",
    "i18next-parser": "6.6.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "openmrs": "next",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "typescript": "^5.4.5"
  },
  "resolutions": {
    "cheerio": "0.22.0",
    "string-width": "4.2.3",
    "strip-ansi": "6.0.1",
    "wrap-ansi": "7.0.0"
  },
  "packageManager": "yarn@4.2.2"
}
